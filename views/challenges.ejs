<%- include('partials/header') %>
<div class="mb-12">
    <h1 class="text-4xl font-bold text-white mb-2">Challenges</h1>
    <p class="text-gray-400">Complete challenges to earn points and climb the leaderboard.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <% challenges.forEach(chal => { %>
        <div class="bg-gray-800 rounded-xl overflow-hidden border border-gray-700 hover:border-blue-500 transition duration-300 shadow-lg flex flex-col">
            <div class="p-6 flex-grow">
                <div class="flex justify-between items-start mb-4">
                    <span class="px-3 py-1 bg-blue-900 text-blue-300 text-xs font-bold rounded-full uppercase tracking-wider">
                        <%= chal.category %>
                    </span>
                    <span class="text-gray-400 font-bold">
                        <%= chal.points %> pts
                    </span>
                </div>
                <h3 class="text-2xl font-bold text-white mb-4"><%= chal.title %></h3>
                <p class="text-gray-400 text-sm mb-6 line-clamp-3">
                    <%= chal.description %>
                </p>
            </div>
            
            <div class="p-6 bg-gray-800/50 border-t border-gray-700 flex items-center justify-between">
                <% if (chal.solved) { %>
                    <span class="text-green-400 font-bold flex items-center">
                        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                        SOLVED
                    </span>
                    <a href="/challenge/<%= chal.id %>" target="_blank" class="text-blue-400 hover:text-blue-300 text-sm font-bold">Details &rarr;</a>
                <% } else { %>
                    <span class="text-gray-500 font-bold italic">Unsolved</span>
                    <a href="/challenge/<%= chal.id %>" target="_blank" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold py-2 px-4 rounded transition duration-200">
                        Open Challenge
                    </a>
                <% } %>
            </div>
        </div>
    <% }) %>
</div>
<%- include('partials/footer') %>
