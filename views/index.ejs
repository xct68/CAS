<%- include('partials/header') %>
<div class="text-center py-20">
    <h1 class="text-5xl font-extrabold text-white mb-6">Welcome to the <span class="text-blue-500">CTF Platform</span></h1>
    <p class="text-gray-400 text-xl mb-10 max-w-2xl mx-auto">
        Test your skills in cryptography, web security, and more. Join us to learn and compete in various challenges.
    </p>
    
    <% if (typeof user !== 'undefined' && user) { %>
        <p class="text-2xl mb-8">Hello, <span class="text-blue-400 font-bold"><%= user.username %></span>!</p>
        <div class="flex justify-center space-x-4">
            <a href="/challenges" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg shadow-lg transition duration-200">View Challenges</a>
            <% if (user.is_admin) { %>
                <a href="/admin" class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 px-8 rounded-lg shadow-lg transition duration-200">Admin Dashboard</a>
            <% } %>
        </div>
    <% } else { %>
        <div class="flex justify-center space-x-4">
            <a href="/login" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg shadow-lg transition duration-200">Get Started</a>
            <a href="/register" class="bg-gray-700 hover:bg-gray-600 text-white font-bold py-3 px-8 rounded-lg shadow-lg transition duration-200">Register</a>
        </div>
    <% } %>
</div>
<%- include('partials/footer') %>
